# Backend API URL (leave blank to use Vite proxy, or set full URL for production)
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized origins: http://localhost:5173 (dev), https://yourdomain.com (prod)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# WhatsApp number for order enquiries (include country code, no +)
VITE_WHATSAPP_NUMBER=919462062626
